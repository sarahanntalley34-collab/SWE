{
  "name": "retro-engineering-demo",
  "version": "1.0.0",
  "description": "Real-time metrics dashboard demo backend — Retro Engineering",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun run --bun tsc --noEmit",
    "start": "bun run src/index.ts",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.40.0",
    "hono": "^4.7.5",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "^1.3.14",
    "@types/jsonwebtoken": "^9.0.9",
    "drizzle-kit": "^0.30.5",
    "typescript": "^5.8.2"
  }
}
